variable DT equal 1
variable TDAMP equal 100*${DT}

thermo_style custom step cpu cpuremain temp press etotal density xlo xhi ylo yhi zlo zhi
thermo 1000


fix 1 all nvt temp 290 290 ${TDAMP} 
run 200000

dump prod all atom 500 prod_traj/density.atom
write_data prod_traj/prod.data

run 1000000