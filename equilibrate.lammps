dihedral_coeff 24 0.000 7.250 0.000 0.000

improper_coeff 1 2.500 -1 2
improper_coeff 2 2.500 -1 2
improper_coeff 3 2.500 -1 2
improper_coeff 4 2.500 -1 2
improper_coeff 5 2.500 -1 2
improper_coeff 6 2.500 -1 2


# Methanol coeffs
mass 13 12.011
mass 14 15.999
mass 15 1.008
mass 16 1.008
mass 17 1.008
mass 18 1.008

pair_coeff 13 13 0.066 3.5000000
pair_coeff 14 14 0.170 3.1200000
pair_coeff 15 15 0.030 2.5000000
pair_coeff 16 16 0.030 2.5000000
pair_coeff 17 17 0.030 2.5000000
pair_coeff 18 18 0.000 0.0000000

bond_coeff 13 320.0000 1.4100
bond_coeff 14 340.0000 1.0900
bond_coeff 15 340.0000 1.0900
bond_coeff 16 340.0000 1.0900
bond_coeff 17 553.0000 0.9450

angle_coeff 19 35.000 109.500
angle_coeff 20 35.000 109.500
angle_coeff 21 35.000 109.500
angle_coeff 22 55.000 108.500
angle_coeff 23 33.000 107.800
angle_coeff 24 33.000 107.800
angle_coeff 25 33.000 107.800

dihedral_coeff 25 0.000 0.000 0.352 0.000
dihedral_coeff 26 0.000 0.000 0.352 0.000
dihedral_coeff 27 0.000 0.000 0.352 0.000

improper_coeff 7 0.000 -1 2
improper_coeff 8 0.000 -1 2


variable DT equal 1
variable TDAMP equal 100*${DT}
variable PDAMP equal 1000*${DT}

minimize 0.0 0.0 10000 100000
timestep ${DT}
fix recenter all recenter INIT INIT INIT

thermo_style custom step cpu cpuremain temp press etotal density xlo xhi ylo yhi zlo zhi
thermo 1000

write_data equil_traj/initial.data
dump equil all atom 500 equil_traj/equil.atom
fix 1 all nvt temp 10 10 ${TDAMP}
run 20000

# heat 
unfix 1
fix 2 all npt temp 10 330 ${TDAMP} iso 1 1 ${PDAMP}
run 100000

# cool 
unfix 2 
fix 3 all npt temp 330 290 ${TDAMP} iso 1 1 ${PDAMP}
run 100000

# NPT density run 
undump equil 
dump density all atom 500 equil_traj/density.atom
write_data equil_traj/density.data

unfix 3 
fix 4 all npt temp 290 290 ${TDAMP} iso 1 1 ${PDAMP}
run 500000




