# PART A - ENERGY MINIMIZATION


# 1) Initialization
units real
atom_style full
bond_style     harmonic
angle_style    harmonic
dihedral_style opls
improper_style cvff
pair_style lj/cut/coul/long 12
pair_modify mix geometric
special_bonds lj/coul 0.0 0.0 0.5
kspace_style pppm 1e-6
neighbor        2.0 bin
neigh_modify    

region box block -15 15 -15 15 -15 15
create_box 18 box bond/types 17 angle/types 25 dihedral/types 27 improper/types 8 &
extra/bond/per/atom 4 extra/angle/per/atom 10 extra/dihedral/per/atom 20 &
 extra/improper/per/atom 4 extra/special/per/atom 20

molecule benzene mol_files/benzene.mol
molecule methanol mol_files/methanol.mol toff 12 boff 12 aoff 18 doff 24 ioff 6
create_atoms 0 random 1 34564 NULL mol benzene 25367 overlap 2
create_atoms 0 random 19 34564 NULL mol methanol 25367 overlap 2


# Benzene coeffs

mass 1 12.011  
mass 2 12.011  
mass 3 12.011  
mass 4 12.011  
mass 5 12.011  
mass 6 12.011  
mass 7 1.008  
mass 8 1.008  
mass 9 1.008  
mass 10 1.008  
mass 11 1.008  
mass 12 1.008  

