angle_coeff 17 63.000 120.000
angle_coeff 18 35.000 120.000

dihedral_coeff 1 0.000 7.250 0.000 0.000
dihedral_coeff 2 0.000 7.250 0.000 0.000
dihedral_coeff 3 0.000 7.250 0.000 0.000
dihedral_coeff 4 0.000 7.250 0.000 0.000
